{
  "name": "file-database-manager",
  "version": "3.0.0",
  "description": "资料管理系统",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "node build.js",
    "dist": "electron-builder --win portable"
  },
  "author": "EZdrang",
  "license": "MIT",
  "dependencies": {},
  "devDependencies": {
    "electron": "^42.4.0",
    "electron-builder": "^26.0.12"
  },
  "build": {
    "appId": "com.ezdrang.filemanager",
    "productName": "资料管理系统",
    "win": {
      "target": ["nsis", "portable", "dir"],
      "icon": "web/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "allowElevation": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "资料管理系统",
      "installerIcon": "web/icon.ico",
      "uninstallerIcon": "web/icon.ico",
      "installerHeaderIcon": "web/icon.ico",
      "artifactName": "file-manager-setup.exe",
      "deleteAppDataOnUninstall": false,
      "runAfterFinish": true
    },
    "portable": {
      "artifactName": "file-manager-portable.exe"
    },
    "directories": {
      "output": "release"
    }
  }
}
