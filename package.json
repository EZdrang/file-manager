{
  "name": "file-manager",
  "version": "3.3.0",
  "description": "资料管理系统 - 现代化本地文件管理工具",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "node build.js",
    "dist": "electron-builder --win portable",
    "dist:win": "electron-builder --win nsis portable",
    "dist:win-arm64": "electron-builder --win --arm64 nsis portable",
    "dist:mac": "electron-builder --mac dmg",
    "dist:linux": "electron-builder --linux deb",
    "dist:all": "electron-builder --win nsis portable --mac dmg --linux deb"
  },
  "author": "EZdrang",
  "license": "MIT",
  "dependencies": {
    "7zip-min": "^3.0.1",
    "exifr": "^7.1.3",
    "mammoth": "^1.12.0",
    "marked": "^18.0.5",
    "trash": "^10.1.1",
    "yauzl": "^3.4.0"
  },
  "devDependencies": {
    "electron": "^42.4.0",
    "electron-builder": "^26.0.12"
  },
  "build": {
    "appId": "com.ezdrang.filemanager",
    "productName": "资料管理系统",
    "copyright": "Copyright © 2026 EZdrang",
    "win": {
      "target": [
        { "target": "nsis", "arch": ["x64", "arm64"] },
        { "target": "portable", "arch": ["x64", "arm64"] }
      ],
      "icon": "web/icon.ico",
      "artifactName": "file-manager-${version}-setup-${arch}.exe"
    },
    "mac": {
      "target": [
        { "target": "dmg", "arch": ["x64", "arm64", "universal"] }
      ],
      "icon": "web/icon.icns",
      "category": "public.app-category.productivity",
      "artifactName": "file-manager-${version}-${arch}.dmg"
    },
    "linux": {
      "target": [
        { "target": "deb", "arch": ["x64", "arm64"] }
      ],
      "icon": "web/icons",
      "category": "Utility;FileTools",
      "artifactName": "file-manager-${version}.${arch}.deb"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "allowElevation": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "资料管理系统",
      "installerIcon": "web/icon.ico",
      "uninstallerIcon": "web/icon.ico",
      "installerHeaderIcon": "web/icon.ico",
      "deleteAppDataOnUninstall": false,
      "runAfterFinish": true
    },
    "portable": {
      "artifactName": "file-manager-${version}-portable-${arch}.exe"
    },
    "dmg": {
      "contents": [
        { "x": 130, "y": 220 },
        { "x": 410, "y": 220, "type": "link", "path": "/Applications" }
      ]
    },
    "directories": {
      "output": "release"
    }
  }
}
